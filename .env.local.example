# =============================================================================
# Local LLM Configuration (LM Studio / Ollama)
# =============================================================================
# Set these to enable local LLM mode

# Enable local LLM (set to "true" to use local instead of Azure)
LOCAL_LLM_ENABLED=true

# LM Studio default (port 1234)
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL_NAME=ministral-3-3b
LOCAL_LLM_PROVIDER_NAME=LM Studio

# Ollama alternative (port 11434)
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL_NAME=llama3.1:8b
# LOCAL_LLM_PROVIDER_NAME=Ollama

# =============================================================================
# Model Selection
# =============================================================================
# Use "azure-openai" for Azure, "local-llm" for local
# If not set, uses first available model
# DEFAULT_MODEL=local-llm

# =============================================================================
# Azure OpenAI (keep for fallback or primary use)
# =============================================================================
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_MODEL_NAME=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
