define user ask out of scope
  "How do I bake a cake?"
  "Tell me a joke"
  "Who won the world cup?"
  "Write a poem about robots"
  "What is the weather today?"
  "Help me with my homework"

define flow user query related to analytics or crm
  user ask about analytics
  bot respond related to analytics

define flow user query related to knowledge hub
  user ask about analytics
  bot respond related to analytics

define flow user query out of scope
  user ask out of scope
  bot refuse to respond out of scope

define bot refuse to respond out of scope
  "I am an specialized AI assistant for Enterprise Systems (D365, Workday, ServiceNow, Microsoft 365, and Armanino Knowledge Hub). I'm afraid I cannot help with that request as it's outside my business domain. [GUARDRAIL_BLOCKED]"

define bot respond related to analytics
  "Certainly, let me process that enterprise request for you."
